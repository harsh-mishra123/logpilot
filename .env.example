# Database
DATABASE_URL=sqlite+aiosqlite:///./logpilot.db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30



# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# WebSocket
WS_MAX_SIZE=1048576  # 1MB
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=20